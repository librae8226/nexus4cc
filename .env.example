# JWT 签名密钥，使用: openssl rand -hex 32
JWT_SECRET=

# 密码 bcrypt hash，使用: htpasswd -bnBC 12 "" yourpassword | tr -d ':\n'
# 或者: node -e "const b=require('bcrypt');b.hash('yourpassword',12).then(h=>console.log(h))"
ACC_PASSWORD_HASH=

# 要 attach 的 tmux session 名
TMUX_SESSION=main

# 宿主机工作区根目录（容器内使用的工作目录）
WORKSPACE_ROOT=/home/librae

# Docker 挂载配置
# 宿主机工作目录路径（默认 /home/librae）
HOST_WORKSPACE=/home/librae
# 容器内工作目录路径（默认 /home/librae，建议保持和宿主机相同路径避免问题）
CONTAINER_WORKSPACE=/home/librae

# 服务监听端口
PORT=3000
